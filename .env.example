# Tenderly credentials (https://dashboard.tenderly.co/account/authorization)
TENDERLY_ACCESS_KEY=your_tenderly_access_key
TENDERLY_ACCOUNT_SLUG=your_account_slug
TENDERLY_PROJECT_SLUG=your_project_slug

# OpenRouter (https://openrouter.ai/keys)
OPEN_ROUTER_API_KEY=sk-or-...

# Etherscan API key — V2 key works for all chains including Berachain
# (https://etherscan.io/myapikey)
ETHERSCAN_API_KEY=

# Alchemy API key — used automatically for all supported chains
# (https://dashboard.alchemy.com)
# Supported: Ethereum, Polygon, Arbitrum, Optimism, Base, Linea,
#            Avalanche, zkSync Era, Blast, Scroll
ALCHEMY_API_KEY=

# Optional RPC overrides — if set, these take priority over Alchemy
# Leave blank to use Alchemy (if key set) or public RPC fallbacks
# RPC_URL_1=
# RPC_URL_56=
# RPC_URL_137=
# RPC_URL_10=
# RPC_URL_42161=
# RPC_URL_8453=
# RPC_URL_43114=
# RPC_URL_59144=
# RPC_URL_324=
# RPC_URL_81457=
# RPC_URL_534352=
# RPC_URL_250=
# RPC_URL_100=
# RPC_URL_80094=

# ── Solana ────────────────────────────────────────────────────────────────────
# Helius API key — optional, enables enriched Solana transaction data
# (https://dev.helius.xyz — free tier: 1M credits/month)
HELIUS_API_KEY=

# Optional Solana RPC overrides (defaults to public mainnet/devnet endpoints)
# SOLANA_RPC_URL=
# SOLANA_DEVNET_RPC_URL=

# ── TON ───────────────────────────────────────────────────────────────────────
# TonAPI key — optional, for higher rate limits (https://tonapi.io)
# Works without a key but rate-limited to ~1 req/sec
# TONAPI_KEY=

# Optional TonAPI base URL overrides (defaults to tonapi.io)
# TONAPI_BASE_URL=https://tonapi.io
# TONAPI_TESTNET_BASE_URL=https://testnet.tonapi.io

# Backend port
PORT=3001

# CORS allowed origin — comma-separated for multiple frontends
# CORS_ORIGIN=http://localhost:5173,http://localhost:5174,https://your-app.vercel.app
